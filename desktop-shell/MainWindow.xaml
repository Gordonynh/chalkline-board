<Window x:Class="OpenWhiteboardDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Chalkline Board"
        Width="1280"
        Height="720"
        MinWidth="960"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="#f3f5f8">
  <Grid>
    <wv2:WebView2 x:Name="WhiteboardView" />
    <Border x:Name="StartupOverlay"
            Panel.ZIndex="10"
            Background="#f3f5f8">
      <Grid>
        <Border Width="360"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="14">
          <StackPanel>
            <TextBlock x:Name="StartupTitle"
                       Text="Chalkline Board &#x6B63;&#x5728;&#x542F;&#x52A8;"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#172033"
                       HorizontalAlignment="Center" />
            <TextBlock Text="&#x6B63;&#x5728;&#x52A0;&#x8F7D;&#x767D;&#x677F;&#x73AF;&#x5883;&#xFF0C;&#x8BF7;&#x7A0D;&#x5019;&#x3002;"
                       Margin="0,12,0,20"
                       FontSize="14"
                       Foreground="#687386"
                       HorizontalAlignment="Center" />
            <ProgressBar IsIndeterminate="True"
                         Height="6"
                         Foreground="#0aa6a6"
                         Background="#e6edf5" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
